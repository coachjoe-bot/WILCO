# ─── WILCO environment variables ─────────────────────────────────────────────
# Copy to .env for local dev (use `vercel dev`, NOT plain `vite`, so /api/* runs).
# Set the same vars in Vercel → Settings → Environment Variables for deploy.

# Supabase (existing)
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
SUPABASE_SERVICE_KEY=        # service_role key — server-side only, never in the client

# Other existing services
VITE_GEMINI_KEY=
RESEND_API_KEY=
VITE_VAPID_PUBLIC_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Client (safe to expose). Use pk_test_... for testing, pk_live_... for production.
VITE_STRIPE_PUBLISHABLE_KEY=

# Server (NEVER expose). sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY=

# Webhook signing secret from `stripe listen` (whsec_...) locally, or from the
# Stripe Dashboard webhook endpoint in production.
STRIPE_WEBHOOK_SECRET=

# Mode switch for the server price map. "test" uses the STRIPE_TEST_PRICE_* IDs
# below; anything else (or unset) uses the hardcoded LIVE price IDs.
STRIPE_MODE=test

# Test-mode price IDs — generate with: node scripts/setup-stripe-test.mjs
STRIPE_TEST_PRICE_PRO_MONTHLY=
STRIPE_TEST_PRICE_PRO_ANNUAL=
STRIPE_TEST_PRICE_ELITE_MONTHLY=
STRIPE_TEST_PRICE_ELITE_ANNUAL=
STRIPE_TEST_PRICE_SCHOOL=

# Gift coupon id (same in live + test if the setup script created it with this id).
STRIPE_GIFT_COUPON_ID=WILCO_GIFT_PRO_MONTH
